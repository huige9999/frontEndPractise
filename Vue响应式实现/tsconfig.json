{
  "compilerOptions": {
    "target": "es2016", // 配置编译目标所使用的ECMAScript版本
    "module": "es6", // 配置编译目标所使用的模块化标准
    "lib": ["DOM","ESNext","DOM.Iterable","ScriptHost"],// 编译时需要的库
    "outDir": "./dist", // 编译后的js所存放的目录
    "strict": true,
    "removeComments": true,
    "esModuleInterop": true // 启用ES模块化交互非ES模块导出
  },
  "include": ["./src"] // 默认编译项目目录下所有的ts文件，这里表示只编译src目录下的ts文件
}